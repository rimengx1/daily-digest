# DeepSeek API Configuration
# 注意：生产环境请使用 .env.local 或在构建时注入环境变量
VITE_DEEPSEEK_API_KEY=your_deepseek_api_key_here

# RSS API Configuration
# 部署 rss-backend 到 Vercel 后，将下面的 URL 替换为实际的 Vercel 域名
# 例如：https://rss-backend-xxxxx.vercel.app
VITE_RSS_API_URL=https://rss-backend-xi.vercel.app
VITE_USE_RSS_API=true
